# ----------------------------------------------
# Covara One - Environment Configuration Template
# ----------------------------------------------
# Copy to .env and fill in your real values.
# NEVER commit .env to version control.

# -- Frontend & Shared Supabase Config --
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -- Backend Only Secrets --
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# -- External API Keys --
OPENWEATHER_API_KEY=your-openweather-key-here
TOMTOM_API_KEY=your-tomtom-key-here
AQI_API_KEY_1=your-data-gov-in-key-here

# -- KYC - Sandbox.co.in (Aadhaar + PAN + Bank Verify) --
SANDBOX_KYC_API_KEY=your-sandbox-kyc-key-here

# -- Twilio (WhatsApp Sandbox + Verify OTP) --
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_SANDBOX_KEYWORD=your-sandbox-keyword

# -- Mobile Device Context Signing (HMAC) --
DEVICE_CONTEXT_HMAC_SECRET=replace-with-64-char-random-secret
# Optional key-id based rotation example:
# DEVICE_CONTEXT_HMAC_SECRET_V2=replace-with-next-rotation-secret

# -- Event Bus / Kafka (Broker-agnostic) --
EVENT_BUS_BACKEND=inmemory
EVENT_BUS_TOPIC_PREFIX=covara
EVENT_BUS_PUBLISH_ON_WRITE=true
EVENT_BUS_INLINE_CONSUMER_ENABLED=true
EVENT_OUTBOX_RELAY_BATCH_SIZE=100
EVENT_OUTBOX_RELAY_ENABLED=true
EVENT_OUTBOX_RELAY_INTERVAL_SECONDS=15
EVENT_OUTBOX_MAX_RETRIES=10
EVENT_CONSUMER_ENABLED=true
EVENT_CONSUMER_GROUP_ID=covara-event-consumers
EVENT_CONSUMER_AUTO_OFFSET_RESET=latest
EVENT_CONSUMER_POLL_TIMEOUT_MS=1000
EVENT_CONSUMER_MAX_RECORDS=100
EVENT_CONSUMER_MAX_ATTEMPTS=5
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=covara-backend
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# -- API & Server --
APP_ENV=development
CORS_ORIGINS=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=/api
REDIS_URL=redis://redis:6379

